    <bpmn:serviceTask id="Activity_140h2m4" name="Store Workpiece in HBW">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">
              <camunda:script scriptFormat="javascript">url = "http://127.0.0.1:5000/process/store_in_hbw_container?color=" + execution.getVariable("color")</camunda:script>
            </camunda:inputParameter>
            <camunda:inputParameter name="method">GET</camunda:inputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
