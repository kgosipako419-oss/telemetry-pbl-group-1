  <bpmn:process id="production_storage_process2" isExecutable="true">
    <bpmn:startEvent id="Event_127z07e" name="Start Production">
      <bpmn:outgoing>Flow_06tular</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="Event_06fuvj7" name="Production ended">
      <bpmn:incoming>Flow_09kyev4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Activity_1e6xoye" name="OV Burn" camunda:asyncBefore="true" camunda:asyncAfter="true" camunda:exclusive="false">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">
              <camunda:script scriptFormat="javascript">url = "http://127.0.0.1:5000/ov/burn?machine=ov_1&amp;time=2"</camunda:script>
            </camunda:inputParameter>
            <camunda:inputParameter name="method">GET</camunda:inputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0v40nih</bpmn:incoming>
      <bpmn:outgoing>Flow_0u2dfsx</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_107pam0" name="Pickup and transport to Oven" camunda:asyncBefore="true" camunda:asyncAfter="true" camunda:exclusive="false">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">
              <camunda:script scriptFormat="javascript">url = "http://127.0.0.1:5000/vgr/pick_up_and_transport?machine=vgr_1&amp;start=color_detection_delivery_pick_up_station&amp;end=oven"</camunda:script>
            </camunda:inputParameter>
            <camunda:inputParameter name="method">GET</camunda:inputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1wclpg0</bpmn:incoming>
      <bpmn:outgoing>Flow_0v40nih</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0v40nih" sourceRef="Activity_107pam0" targetRef="Activity_1e6xoye" />
    <bpmn:serviceTask id="Activity_1vvxp20" name="Get Workpiece from Pickup Station">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">
              <camunda:script scriptFormat="javascript">url = "http://127.0.0.1:5000/vgr/pick_up_and_transport?machine=vgr_1&amp;start=delivery_pick_up_station&amp;end=color_detection_delivery_pick_up_station"</camunda:script>
            </camunda:inputParameter>
            <camunda:inputParameter name="method">GET</camunda:inputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_06tular</bpmn:incoming>
      <bpmn:outgoing>Flow_1odrk7g</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Activity_0d7zwb0" name="Read Color">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">
              <camunda:script scriptFormat="javascript">url = "http://127.0.0.1:5000/vgr/read_color?machine=vgr_1"</camunda:script>
            </camunda:inputParameter>
            <camunda:inputParameter name="method">GET</camunda:inputParameter>
            <camunda:outputParameter name="color">${JSON(response).jsonPath("$.attributes[0].current_color").stringValue()}</camunda:outputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_1odrk7g</bpmn:incoming>
      <bpmn:outgoing>Flow_1wclpg0</bpmn:outgoing>
