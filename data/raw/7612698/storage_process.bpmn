  <bpmn:process id="storage_process_new2" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Start Storage">
      <bpmn:outgoing>Flow_0kkbt7j</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Activity_0sy1do2" name="Get Workpiece from Pickup Station">
      <bpmn:extensionElements>
        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">
              <camunda:script scriptFormat="javascript">url = "http://127.0.0.1:5000/vgr/pick_up_and_transport?machine=vgr_1&amp;start=delivery_pick_up_station&amp;end=color_detection_delivery_pick_up_station"</camunda:script>
            </camunda:inputParameter>
            <camunda:inputParameter name="method">GET</camunda:inputParameter>
          </camunda:inputOutput>
          <camunda:connectorId>http-connector</camunda:connectorId>
        </camunda:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0kkbt7j</bpmn:incoming>
      <bpmn:outgoing>Flow_1xmyk56</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_0kkbt7j" sourceRef="StartEvent_1" targetRef="Activity_0sy1do2" />
    <bpmn:endEvent id="Event_09poftp" name="Storage ended">
      <bpmn:incoming>Flow_0iikjkt</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Activity_1auyxwx" name="Calibrate HBW">
