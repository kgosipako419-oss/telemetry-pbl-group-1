        <camunda:connector>
          <camunda:inputOutput>
            <camunda:inputParameter name="url">
              <camunda:script scriptFormat="javascript">url = "http://127.0.0.1:5000/mm/mill?machine=mm_1&amp;start=initial&amp;end=ejection&amp;time=1"</camunda:script>
            </camunda:inputParameter>
            <camunda:inputParameter name="method">GET</camunda:inputParameter>
          </camunda:inputOutput>
