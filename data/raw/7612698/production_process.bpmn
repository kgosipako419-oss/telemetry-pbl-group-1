          <camunda:inputOutput>
            <camunda:inputParameter name="url">
              <camunda:script scriptFormat="javascript">url = "http://127.0.0.1:5000/vgr/pick_up_and_transport?machine=vgr_1&amp;start=sink_" + execution.getVariable("sink") + "&amp;end=high_bay_warehouse_delivery_station"</camunda:script>
